---
interface Props {
  title: string;
  lede?: string;
  category?: string;
  tags?: string[];
  repo_label?: string;
  github_url?: string;
  href: string;
}

const { title, lede, category, tags, repo_label, github_url, href } = Astro.props;

const categoryColors: Record<string, string> = {
  Specification: 'bg-purple-500/15 text-purple-300 border-purple-500/30',
  Blueprint: 'bg-blue-500/15 text-blue-300 border-blue-500/30',
  Prompt: 'bg-green-500/15 text-green-300 border-green-500/30',
  Reminder: 'bg-amber-500/15 text-amber-300 border-amber-500/30',
};

const categoryStyle = category ? categoryColors[category] || 'bg-muted text-muted-foreground' : '';
---

<a href={href} class="block group">
  <article class="border border-border rounded-lg p-5 hover:border-primary/50 transition-colors bg-card">
    <div class="flex items-start justify-between gap-3 mb-2">
      <h3 class="text-lg font-semibold text-foreground group-hover:text-primary transition-colors leading-tight">
        {title}
      </h3>
      {category && (
        <span class={`text-xs font-medium px-2 py-0.5 rounded-full border shrink-0 ${categoryStyle}`}>
          {category}
        </span>
      )}
    </div>

    {lede && (
      <p class="text-sm text-muted-foreground mb-3 line-clamp-2">{lede}</p>
    )}

    <div class="flex items-center gap-3 flex-wrap">
      {repo_label && (
        <span class="text-xs text-muted-foreground">
          {repo_label}
        </span>
      )}

      {tags && tags.length > 0 && (
        <div class="flex gap-1.5 flex-wrap">
          {tags.slice(0, 5).map(tag => (
            <span class="text-xs px-1.5 py-0.5 rounded bg-muted text-muted-foreground">
              {tag}
            </span>
          ))}
          {tags.length > 5 && (
            <span class="text-xs text-muted-foreground">+{tags.length - 5}</span>
          )}
        </div>
      )}
    </div>
  </article>
</a>
