---
import brand from '@brand';
import SocialsFaviconRow from './SocialsFaviconRow.astro';
---
<header class="px-6 py-4">
  <div class="gradient-line mb-0"></div>
  <nav class="max-w-6xl mx-auto flex items-center justify-between">
    <a href="/" class="hover:opacity-80 transition-opacity">
      <img src={brand.assets?.logoDark} alt={brand.name} class="h-8 w-auto" />
    </a>
    <div class="flex items-center gap-6 text-sm font-medium">
      <a href="/portfolio" class="text-muted-foreground hover:text-foreground transition-colors">Portfolio</a>
      <a href="/blog" class="text-muted-foreground hover:text-foreground transition-colors">Blog</a>
      <a href="/posts" class="text-muted-foreground hover:text-foreground transition-colors">Posts</a>
      <a href="/about" class="text-muted-foreground hover:text-foreground transition-colors">About</a>
      <a href="/cv" class="text-muted-foreground hover:text-foreground transition-colors">CV</a>
      <SocialsFaviconRow />
    </div>
  </nav>
</header>
