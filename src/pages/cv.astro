---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="CV - Michael Staton" description="Curriculum Vitae of Michael Staton. Venture capital, fund formation, founder experience, and thought leadership.">

  <!-- Hero -->
  <section class="max-w-5xl mx-auto px-6 pt-16 pb-12">
    <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-6 mb-8">
      <div>
        <h1 class="gradient-text mb-2">Michael Staton</h1>
        <p class="text-xl text-muted-foreground">Venture Capital &middot; Fund Formation &middot; Founder</p>
      </div>
      <div class="flex gap-3 text-sm">
        <a href="https://www.linkedin.com/in/mpstaton/" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-md border border-border text-muted-foreground hover:text-foreground hover:bg-muted transition-colors">
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
          LinkedIn
        </a>
        <a href="/portfolio" class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-md gradient-bg text-white hover:opacity-90 transition-opacity">
          View Track Record
        </a>
      </div>
    </div>
    <div class="gradient-line"></div>
  </section>

  <!-- At a Glance Stats -->
  <section class="max-w-5xl mx-auto px-6 pb-16">
    <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-12">
      <a href="/portfolio" class="rounded-lg border border-border bg-card p-5 text-center hover:border-primary/50 hover:-translate-y-0.5 transition-all">
        <div class="text-3xl font-bold gradient-text">3.5</div>
        <div class="text-sm text-muted-foreground mt-1">VC Firms Founded</div>
      </a>
      <a href="/portfolio" class="rounded-lg border border-border bg-card p-5 text-center hover:border-primary/50 hover:-translate-y-0.5 transition-all">
        <div class="text-3xl font-bold gradient-text">$300M+</div>
        <div class="text-sm text-muted-foreground mt-1">Capital Raised</div>
      </a>
      <a href="/portfolio" class="rounded-lg border border-border bg-card p-5 text-center hover:border-primary/50 hover:-translate-y-0.5 transition-all">
        <div class="text-3xl font-bold gradient-text">200+</div>
        <div class="text-sm text-muted-foreground mt-1">Companies Invested</div>
      </a>
      <a href="/portfolio" class="rounded-lg border border-border bg-card p-5 text-center hover:border-primary/50 hover:-translate-y-0.5 transition-all">
        <div class="text-3xl font-bold gradient-text">4</div>
        <div class="text-sm text-muted-foreground mt-1">IPOs</div>
      </a>
    </div>

    <!-- TLDR -->
    <div class="rounded-lg border border-border bg-card p-6 mb-12">
      <h2 class="text-lg font-semibold text-foreground mb-3">TLDR</h2>
      <p class="text-muted-foreground leading-relaxed mb-4">
        Grew Learn Capital from $40M AUM to $1.2B AUM. Raised over $300M USD across multiple fund vehicles.
        4 IPOs: Coursera, Udemy, Nerdy (Varsity Tutors), and Chime. Notable acquisitions include Careem ~$3B to Uber,
        NearPod ~$700M to Renaissance, PhotoMath ~$500M to Google, General Assembly ~$375M to Adecco.
      </p>
      <p class="text-muted-foreground leading-relaxed">
        Unrealized portfolio includes several unicorns: Harmonic, Thinking Machines, Aalo Atomics, Andela, Maven Clinic, Ontra, and Outschool.
        Personal angel portfolio of 30 companies with ~7x MOIC and ~30% annual IRR.
      </p>
    </div>

    <!-- Skills -->
    <div class="mb-16">
      <h2 class="text-lg font-semibold text-foreground mb-4">Core Competencies</h2>
      <div class="flex flex-wrap gap-2">
        {['Venture Capital', 'Capital Formation', 'Investor Relations & Fundraising', 'Foresight', 'Decision Science', 'Data Operations', 'Materials Generation', 'Workflow Automation & Agentic Workforces', 'Vibe Coding', 'Digital Marketing (Full Stack)'].map(skill => (
          <span class="px-3 py-1.5 rounded-md text-sm font-medium border border-[#9138E0]/20 bg-[#9138E0]/8 text-[#9138E0]">{skill}</span>
        ))}
      </div>
      <div class="flex flex-wrap gap-2 mt-3">
        {['Entrepreneurship', 'Thought-Leadership Marketing', 'Presentations & Slide Design', 'Customer Development', 'Product Strategy', 'Design Thinking', 'Inside Sales', 'Long-Form Writing', 'Pedagogy'].map(skill => (
          <span class="px-3 py-1.5 rounded-md text-sm font-medium border border-border bg-muted/50 text-muted-foreground">{skill}</span>
        ))}
      </div>
    </div>
  </section>

  <!-- Venture Experience -->
  <section class="max-w-5xl mx-auto px-6 pb-16">
    <div class="flex items-center gap-3 mb-8">
      <div class="gradient-line flex-1" style="max-width:3rem"></div>
      <h2 class="text-2xl font-bold text-foreground">Venture Experience</h2>
      <div class="gradient-line flex-1"></div>
    </div>

    <div class="space-y-0">
      <!-- Learn Capital -->
      <div class="cv-role">
        <div class="cv-timeline">
          <div class="cv-dot"></div>
          <div class="cv-line"></div>
        </div>
        <div class="cv-content">
          <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-1 mb-2">
            <div>
              <h3 class="text-foreground font-semibold text-lg">Learn Capital</h3>
              <p class="text-sm text-muted-foreground">San Mateo, CA</p>
            </div>
            <span class="text-sm text-muted-foreground whitespace-nowrap">Oct 2012 &ndash; Present</span>
          </div>
          <div class="space-y-2 mb-3">
            <div class="flex flex-wrap gap-2">
              <span class="cv-title-badge">Venture Partner</span>
              <span class="cv-date-badge">Oct 2019 &ndash; Present</span>
            </div>
            <div class="flex flex-wrap gap-2">
              <span class="cv-title-badge">Founder & GP, LearnStart</span>
              <span class="cv-date-badge">Feb 2017 &ndash; Present</span>
            </div>
            <div class="flex flex-wrap gap-2">
              <span class="cv-title-badge">General Partner</span>
              <span class="cv-date-badge">May 2015 &ndash; Oct 2019</span>
            </div>
            <div class="flex flex-wrap gap-2">
              <span class="cv-title-badge">Partner</span>
              <span class="cv-date-badge">Dec 2013 &ndash; May 2015</span>
            </div>
            <div class="flex flex-wrap gap-2">
              <span class="cv-title-badge">Entrepreneur-in-Residence</span>
              <span class="cv-date-badge">Oct 2012 &ndash; Dec 2013</span>
            </div>
          </div>
          <ul class="cv-bullets">
            <li>Raised $85M+ in capital; sourced 14 new LPs for $150M Fund III (IRR 25%+), over $120M for Fund IV</li>
            <li>Increased LP contacts 900%. Managed 70% of dealflow</li>
            <li>Founded LearnStart, seed fund of Learn Capital (Fund I &amp; Fund II ~$25M, ~$50M AUM, IRR: 35%+)</li>
            <li>Investments into Coursera, Minerva, Brilliant, PhotoMath, SoloLearn, and others</li>
            <li>Primary presenter to Investment Committee. Led marketing, outreach, and thought-leadership</li>
          </ul>
        </div>
      </div>

      <!-- Hypernova Capital -->
      <div class="cv-role">
        <div class="cv-timeline">
          <div class="cv-dot"></div>
          <div class="cv-line"></div>
        </div>
        <div class="cv-content">
          <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-1 mb-2">
            <div>
              <h3 class="text-foreground font-semibold text-lg">Hypernova Capital</h3>
              <p class="text-sm text-muted-foreground">SF, Miami, Istanbul &middot; $30M AUM</p>
            </div>
            <span class="text-sm text-muted-foreground whitespace-nowrap">Aug 2024 &ndash; Present</span>
          </div>
          <div class="flex flex-wrap gap-2 mb-3">
            <span class="cv-title-badge">Cofounder, Catalyst, General Partner</span>
          </div>
          <ul class="cv-bullets">
            <li>Developed fund strategy; created fundraising materials and dataroom</li>
            <li>Helped augment capital raise, bolster deal sourcing, source and win key investments</li>
            <li>Sourced and diligenced LP commitments and direct seed investments</li>
          </ul>
        </div>
      </div>

      <!-- Alpha Partners -->
      <div class="cv-role">
        <div class="cv-timeline">
          <div class="cv-dot"></div>
          <div class="cv-line"></div>
        </div>
        <div class="cv-content">
          <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-1 mb-2">
            <div>
              <h3 class="text-foreground font-semibold text-lg">Alpha Partners</h3>
              <p class="text-sm text-muted-foreground">New York, NY</p>
            </div>
            <span class="text-sm text-muted-foreground whitespace-nowrap">Oct 2019 &ndash; Present</span>
          </div>
          <div class="flex flex-wrap gap-2 mb-3">
            <span class="cv-title-badge">Venture Partner</span>
          </div>
          <ul class="cv-bullets">
            <li>Sourced investments into Careem, Udemy, and Coursera</li>
            <li>Participated in investments into SpotHero, Lime, Gecko Robotics, Getaround, Ro, Brave Health, and Thirty Madison</li>
            <li>Increased LP and GP networks. Managed networking events in SF and Silicon Valley</li>
            <li>Fund II IRR of 35%+</li>
          </ul>
        </div>
      </div>

      <!-- Laerdal Million Lives Fund -->
      <div class="cv-role">
        <div class="cv-timeline">
          <div class="cv-dot"></div>
          <div class="cv-line"></div>
        </div>
        <div class="cv-content">
          <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-1 mb-2">
            <div>
              <h3 class="text-foreground font-semibold text-lg">Laerdal Million Lives Fund</h3>
              <p class="text-sm text-muted-foreground">SF &middot; Stavanger, Norway</p>
            </div>
            <span class="text-sm text-muted-foreground whitespace-nowrap">Oct 2018 &ndash; Oct 2019</span>
          </div>
          <div class="flex flex-wrap gap-2 mb-3">
            <span class="cv-title-badge">Co-Conspirator & Catalyst</span>
          </div>
          <ul class="cv-bullets">
            <li>Strategy and stakeholder management across $600M family office, global operating company, and Board of Directors</li>
            <li>Secured $100M USD anchor for hybrid fund (Impact/Venture, Fund of Funds/Direct)</li>
            <li>Recruited early team, generated strategy materials, sourced first investments</li>
          </ul>
        </div>
      </div>

      <!-- NewSchools -->
      <div class="cv-role">
        <div class="cv-timeline">
          <div class="cv-dot"></div>
          <div class="cv-line"></div>
        </div>
        <div class="cv-content">
          <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-1 mb-2">
            <div>
              <h3 class="text-foreground font-semibold text-lg">NewSchools Venture Fund Seed</h3>
              <p class="text-sm text-muted-foreground">Oakland, CA &middot; Spun out as Reach Capital</p>
            </div>
            <span class="text-sm text-muted-foreground whitespace-nowrap">Oct 2011 &ndash; Oct 2014</span>
          </div>
          <div class="flex flex-wrap gap-2 mb-3">
            <span class="cv-title-badge">Venture Partner & Community Advisor</span>
          </div>
          <ul class="cv-bullets">
            <li>Managed dealflow; participated in investment committee meetings</li>
            <li>Investments into NearPod, Curriculet, Ellevation, and Educreations</li>
          </ul>
        </div>
      </div>

      <!-- Kauffman Fellows -->
      <div class="cv-role">
        <div class="cv-timeline">
          <div class="cv-dot"></div>
          <div class="cv-line"></div>
        </div>
        <div class="cv-content">
          <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-1 mb-2">
            <div>
              <h3 class="text-foreground font-semibold text-lg">Kauffman Fellows</h3>
              <p class="text-sm text-muted-foreground">Class 20</p>
            </div>
            <span class="text-sm text-muted-foreground whitespace-nowrap">Jun 2015 &ndash; Present</span>
          </div>
          <ul class="cv-bullets">
            <li>Curriculum Advisory Board formation and current member. Class Chair</li>
            <li>Jeff Timmons Award for Outstanding Leadership among 40 fund managers (2017)</li>
            <li>Catalyst of "Peer Learning" &mdash; accelerated, self-organized learning for each class</li>
            <li>Mentor to Class Chair in Classes 21, 22, 23, 24, and 25</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- Founder Experience -->
  <section class="max-w-5xl mx-auto px-6 pb-16">
    <div class="flex items-center gap-3 mb-4">
      <div class="gradient-line flex-1" style="max-width:3rem"></div>
      <h2 class="text-2xl font-bold text-foreground">Founder Experience</h2>
      <div class="gradient-line flex-1"></div>
    </div>
    <p class="text-muted-foreground mb-8">Raised over $20M in capital as founder CEO, took to Series B. 2 exits, one ongoing.</p>

    <div class="space-y-0">
      <!-- Colearn -->
      <div class="cv-role">
        <div class="cv-timeline">
          <div class="cv-dot cv-dot--founder"></div>
          <div class="cv-line"></div>
        </div>
        <div class="cv-content">
          <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-1 mb-2">
            <div>
              <h3 class="text-foreground font-semibold text-lg">Colearn Academy</h3>
              <p class="text-sm text-muted-foreground">Remote</p>
            </div>
            <span class="text-sm text-muted-foreground whitespace-nowrap">Mar 2020 &ndash; Jan 2025</span>
          </div>
          <div class="flex flex-wrap gap-2 mb-3">
            <span class="cv-title-badge">Founder, CEO</span>
          </div>
          <ul class="cv-bullets">
            <li>Raised pre-seed and seed rounds. Led product and curriculum vision</li>
            <li>Achieved state authorization to open and operate a virtual public charter school in Arizona</li>
            <li>Surpassed goal and cap of 180 full-time students. 84 NPS from parents</li>
            <li>Designed and implemented innovative education model, "Colearning"</li>
          </ul>
        </div>
      </div>

      <!-- Dev Bootcamp -->
      <div class="cv-role">
        <div class="cv-timeline">
          <div class="cv-dot cv-dot--founder"></div>
          <div class="cv-line"></div>
        </div>
        <div class="cv-content">
          <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-1 mb-2">
            <div>
              <h3 class="text-foreground font-semibold text-lg">Dev Bootcamp</h3>
              <p class="text-sm text-muted-foreground">San Francisco, CA</p>
            </div>
            <span class="text-sm text-muted-foreground whitespace-nowrap">Oct 2012 &ndash; Feb 2013</span>
          </div>
          <div class="flex flex-wrap gap-2 mb-3">
            <span class="cv-title-badge">Special Advisor to CEO</span>
          </div>
          <ul class="cv-bullets">
            <li>Created growth strategy. Early media and PR wins</li>
            <li>Established elements of company culture affecting 4,000+ graduates</li>
            <li>Recruited key executives. <em>Acquired by Kaplan</em></li>
          </ul>
        </div>
      </div>

      <!-- Uversity -->
      <div class="cv-role">
        <div class="cv-timeline">
          <div class="cv-dot cv-dot--founder"></div>
          <div class="cv-line"></div>
        </div>
        <div class="cv-content">
          <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-1 mb-2">
            <div>
              <h3 class="text-foreground font-semibold text-lg">Uversity <span class="text-muted-foreground font-normal text-sm">(formerly Inigral)</span></h3>
              <p class="text-sm text-muted-foreground">San Francisco, CA</p>
            </div>
            <span class="text-sm text-muted-foreground whitespace-nowrap">Jul 2007 &ndash; Oct 2012</span>
          </div>
          <div class="space-y-2 mb-3">
            <div class="flex flex-wrap gap-2">
              <span class="cv-title-badge">Co-Founder, CEO</span>
              <span class="cv-date-badge">Jul 2007 &ndash; Oct 2011</span>
            </div>
            <div class="flex flex-wrap gap-2">
              <span class="cv-title-badge">Chief Evangelist</span>
              <span class="cv-date-badge">Oct 2011 &ndash; Oct 2012</span>
            </div>
          </div>
          <ul class="cv-bullets">
            <li>Raised $7M from Founders Fund, Retro Ventures, Bill & Melinda Gates Foundation, and Western Technology Investments</li>
            <li>Closed 20+ accounts, led 500% one-year customer growth, built team of 30</li>
            <li>Functional head of Customer Development, Market Development, and Product Strategy</li>
            <li><em>Acquired by TargetX</em></li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- Distinguishments -->
  <section class="max-w-5xl mx-auto px-6 pb-16">
    <div class="flex items-center gap-3 mb-8">
      <div class="gradient-line flex-1" style="max-width:3rem"></div>
      <h2 class="text-2xl font-bold text-foreground">Distinguishments</h2>
      <div class="gradient-line flex-1"></div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
      <div class="rounded-lg border border-border bg-card p-5">
        <span class="text-xs font-mono text-[#F59C49]">2025</span>
        <p class="text-foreground font-medium mt-1">EiR Entrepreneur & Team Coach, Perago</p>
        <p class="text-sm text-muted-foreground">Life sciences accelerator, SFU Venture Labs</p>
      </div>
      <div class="rounded-lg border border-border bg-card p-5">
        <span class="text-xs font-mono text-[#F59C49]">2024</span>
        <p class="text-foreground font-medium mt-1">LP Fundraising Bootcamp, Instructor</p>
        <p class="text-sm text-muted-foreground">Week-long workshop across Poland, Lithuania, Latvia, and Estonia</p>
      </div>
      <div class="rounded-lg border border-border bg-card p-5">
        <span class="text-xs font-mono text-[#F59C49]">2017</span>
        <p class="text-foreground font-medium mt-1">Jeff Timmons Award for Outstanding Leadership</p>
        <p class="text-sm text-muted-foreground">Kauffman Fellowship, among 40 fund managers</p>
      </div>
      <div class="rounded-lg border border-border bg-card p-5">
        <span class="text-xs font-mono text-[#F59C49]">2012</span>
        <p class="text-foreground font-medium mt-1">Contributing Author</p>
        <p class="text-sm text-muted-foreground">"Stretching the Higher Education Dollar"</p>
      </div>
    </div>

    <div class="mt-6 rounded-lg border border-border bg-muted/30 p-5">
      <h3 class="text-sm font-semibold text-foreground mb-3">Speaking & Advisory</h3>
      <p class="text-sm text-muted-foreground leading-relaxed">
        Regular speaker, panelist, and keynote across global venues including
        SxSW EDU, ASU Education Innovation Summit, Edtech Europe, World Innovation Summit for Education (Doha),
        Slush (Helsinki), South Summit (Madrid), GET (Beijing), ADC Forum (Melbourne), Switch (San Miguel de Allende),
        Center for Universal Education at Brookings Institution, American Enterprise Institute, EDUCAUSE, and Impact Capitalism Summit.
      </p>
    </div>
  </section>

  <!-- Education -->
  <section class="max-w-5xl mx-auto px-6 pb-16">
    <div class="flex items-center gap-3 mb-8">
      <div class="gradient-line flex-1" style="max-width:3rem"></div>
      <h2 class="text-2xl font-bold text-foreground">Education</h2>
      <div class="gradient-line flex-1"></div>
    </div>

    <div class="rounded-lg border border-border bg-card p-6 mb-6">
      <h3 class="text-foreground font-semibold mb-2">Kauffman Fellowship, Class 20</h3>
      <p class="text-sm text-muted-foreground">Selected as one of 40 fellows. Class Chair. Catalyst and Benevolent Dictator of Peer Learning Series. 2015 &ndash; Present.</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      <div class="rounded-lg border border-border bg-card p-6">
        <div class="flex items-start justify-between mb-2">
          <h3 class="text-foreground font-semibold">MA, International Development</h3>
          <span class="text-xs text-muted-foreground font-mono">2003 / 2006</span>
        </div>
        <p class="text-sm text-muted-foreground mb-2">Clark University</p>
        <p class="text-xs text-muted-foreground italic">"Towards Understanding and Managing Unintended Consequences in Economic Systems"</p>
      </div>
      <div class="rounded-lg border border-border bg-card p-6">
        <div class="flex items-start justify-between mb-2">
          <h3 class="text-foreground font-semibold">BA, Program of Liberal Studies</h3>
          <span class="text-xs text-muted-foreground font-mono">2002</span>
        </div>
        <p class="text-sm text-muted-foreground mb-2">Clark University &middot; International Studies Stream</p>
        <p class="text-xs text-muted-foreground">Valedictory Speaker &middot; Gamma Theta Upsilon<br/>Geography & GIS &middot; Asian Studies, Mandarin Chinese<br/>Student Government President</p>
      </div>
    </div>
  </section>

  <!-- Current Passions -->
  <section class="max-w-5xl mx-auto px-6 pb-16">
    <div class="flex items-center gap-3 mb-8">
      <div class="gradient-line flex-1" style="max-width:3rem"></div>
      <h2 class="text-2xl font-bold text-foreground">Current Passions</h2>
      <div class="gradient-line flex-1"></div>
    </div>
    <div class="flex flex-wrap gap-2">
      {['Digital Storytelling', 'AI Content Generation', 'Static-Site Generators', 'Vibe Coding', 'Visual Leadership', 'Concept Communication', 'Digital Illustration & Animated Infographics', 'Content Models', 'Iconography', 'Long-Term Reputational Gaming', 'Collaboratively-Directed-Opinionated-Open-Source'].map(passion => (
        <span class="px-3 py-1.5 rounded-md text-sm font-medium border border-[#22A6B5]/20 bg-[#22A6B5]/8 text-[#22A6B5]">{passion}</span>
      ))}
    </div>
    <p class="text-sm text-muted-foreground mt-4">
      Current content generation and market research under the umbrella brand <a href="https://www.lossless.group/" target="_blank" rel="noopener noreferrer" class="text-[#22A6B5] hover:underline">The Lossless Group</a>.
    </p>
  </section>

</BaseLayout>

<style is:global>
  .cv-role {
    display: flex;
    gap: 1.25rem;
    position: relative;
  }
  .cv-timeline {
    display: flex;
    flex-direction: column;
    align-items: center;
    flex-shrink: 0;
    width: 1.25rem;
    padding-top: 0.375rem;
  }
  .cv-dot {
    width: 0.75rem;
    height: 0.75rem;
    border-radius: 50%;
    background: var(--gradient-brand);
    flex-shrink: 0;
    z-index: 1;
  }
  .cv-dot--founder {
    background: var(--brand-orange);
  }
  .cv-line {
    width: 2px;
