---
import BaseLayout from '../../layouts/BaseLayout.astro';
---
<BaseLayout title="Posts - MP Staton" description="Curated posts and links on technology, venture, and systems thinking.">
  <section class="max-w-4xl mx-auto px-6 py-16">
    <h1 class="text-foreground mb-4">Posts</h1>
    <p class="text-lg text-muted-foreground mb-12">
      A curated aggregation of posts, links, and commentary from across the web.
    </p>

    <div class="space-y-8">
      <p class="text-muted-foreground py-12 text-center border border-dashed border-border rounded-lg">
        Post aggregation coming soon. This will pull from various sources and feeds.
      </p>
    </div>
  </section>
</BaseLayout>
