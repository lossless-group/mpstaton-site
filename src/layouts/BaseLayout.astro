---
import '../styles/globals.css';
import brand from '@brand';
import { SITE_SEO } from '../config/seo';

interface Props {
  title?: string;
  description?: string;
}

const { title = SITE_SEO.defaultTitle, description = SITE_SEO.defaultDescription } = Astro.props;
const SITE_MODE = import.meta.env.SITE_MODE ?? 'dark';
---
<html lang="en" data-theme={SITE_MODE} style={`--primary:${brand.colors.primary};--secondary:${brand.colors.secondary};--accent:${brand.colors.accent};`}>
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href={brand.assets?.favicon ?? '/favicon.svg'} />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <title>{title}</title>
  </head>
  <body class="min-h-screen flex flex-col">
    <header class="px-6 py-4">
      <div class="gradient-line mb-0"></div>
      <nav class="max-w-6xl mx-auto flex items-center justify-between">
        <a href="/" class="hover:opacity-80 transition-opacity">
          <img src={brand.assets?.logoDark} alt={brand.name} class="h-8 w-auto" />
        </a>
        <div class="flex gap-6 text-sm font-medium">
          <a href="/portfolio" class="text-muted-foreground hover:text-foreground transition-colors">Portfolio</a>
          <a href="/blog" class="text-muted-foreground hover:text-foreground transition-colors">Blog</a>
          <a href="/posts" class="text-muted-foreground hover:text-foreground transition-colors">Posts</a>
          <a href="/about" class="text-muted-foreground hover:text-foreground transition-colors">About</a>
        </div>
      </nav>
    </header>
    <main class="flex-1">
      <slot />
    </main>
    <footer class="border-t border-border px-6 py-8">
      <div class="max-w-6xl mx-auto text-center text-muted-foreground text-sm">
        &copy; {new Date().getFullYear()} MP Staton. All rights reserved.
      </div>
    </footer>
  </body>
</html>
