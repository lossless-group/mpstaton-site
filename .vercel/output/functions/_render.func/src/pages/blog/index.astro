---
import BaseLayout from '../../layouts/BaseLayout.astro';
---
<BaseLayout title="Blog - MP Staton" description="Thoughts on investing, building, and technology.">
  <section class="max-w-4xl mx-auto px-6 py-16">
    <h1 class="text-foreground mb-4">Blog</h1>
    <p class="text-lg text-muted-foreground mb-12">
      Thoughts on investing, building, and the evolving technology landscape.
    </p>

    <div class="space-y-8">
      <p class="text-muted-foreground py-12 text-center border border-dashed border-border rounded-lg">
        Blog posts coming soon. Content will be driven by Astro content collections.
      </p>
    </div>
  </section>
</BaseLayout>
